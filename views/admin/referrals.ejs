<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <div class="dashboard-grid">
        <aside class="dashboard-sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/owner">Dashboard</a></li>
                <li><a href="/admin/owner/calendar">Calendar</a></li>
                <li><a href="/admin/owner/availability">Availability</a></li>
                <li><a href="/admin/owner/tutors">Tutors</a></li>
                <li><a href="/admin/owner/students">Students</a></li>
                <li><a href="/admin/owner/sheets">Session Sheets</a></li>
                <li><a href="/admin/owner/messages">Messages</a></li>
                <li><a href="/admin/owner/audit-log">Audit Log</a></li>
                <li><a href="/admin/owner/blog">Blog</a></li>
                <li><a href="/admin/owner/referrals" class="active">Referrals</a></li>
                <li><a href="/admin/owner/settings">Settings</a></li>
                <li><a href="/admin/owner/profile">My Profile</a></li>
            </ul>
        </aside>
        <div class="dashboard-main">
            <h1 style="font-size:1.5rem;margin-bottom:24px;">Referral Codes</h1>
            <div class="card" style="padding:24px;margin-bottom:24px;">
                <h3 style="font-size:1.1rem;margin-bottom:16px;">Generate New Code</h3>
                <form action="/admin/owner/referral-code" method="POST" style="display:flex;gap:12px;flex-wrap:wrap;align-items:end;"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-group" style="margin:0;"><label>Discount %</label><input type="number" name="discount_percent" value="10" class="form-control" style="width:80px;" min="1" max="100"></div>
                    <div class="form-group" style="margin:0;flex:1;min-width:200px;"><label>Note (optional)</label><input type="text" name="note" class="form-control" placeholder="e.g., For John's family"></div>
                    <button type="submit" class="btn btn-primary">Generate</button>
                </form>
            </div>
            <div class="table-wrapper">
                <table>
                    <thead><tr><th>Code</th><th>Discount</th><th>Note</th><th>Status</th><th>Used By</th><th>Created</th></tr></thead>
                    <tbody>
                        <% codes.forEach(c => { %>
                        <tr>
                            <td><strong style="font-family:monospace;"><%= c.code %></strong></td>
                            <td><%= c.discount_percent %>%</td>
                            <td><%= c.note || '' %></td>
                            <td><span class="badge-status <%= c.used_by ? 'badge-completed' : 'badge-active' %>"><%= c.used_by ? 'Used' : 'Active' %></span></td>
                            <td><%= c.used_first ? c.used_first + ' ' + c.used_last : '' %></td>
                            <td><%= new Date(c.created_at).toLocaleDateString() %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>

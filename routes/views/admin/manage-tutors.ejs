<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<% const subjectOptions = ['Math', 'Algebra', 'Geometry', 'Calculus', 'Statistics', 'Science', 'Biology', 'Chemistry', 'Physics', 'English', 'Writing', 'Reading', 'Literature', 'History', 'Social Studies', 'Geography', 'French', 'Spanish', 'Mandarin', 'Computer Science', 'Coding', 'SAT Prep', 'ACT Prep', 'Test Strategy', 'Study Skills', 'Art', 'Music']; %>

<main id="main-content">
    <div class="dashboard-grid">
        <aside class="dashboard-sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/owner">&#x1F3E0; Dashboard</a></li>
                <li><a href="/admin/owner/calendar">&#x1F4C5; Calendar</a></li>
                <li><a href="/admin/owner/availability">&#x1F552; Availability</a></li>
                <li><a href="/admin/owner/tutors" class="active">&#x1F468;&#x200D;&#x1F3EB; Tutors</a></li>
                <li><a href="/admin/owner/students">&#x1F393; Students</a></li>
                <li><a href="/admin/owner/blog">&#x1F4DD; Blog</a></li>
                <li><a href="/admin/owner/referrals">&#x1F381; Referrals</a></li>
                <li><a href="/admin/owner/settings">&#x2699;&#xFE0F; Settings</a></li>
                <li><a href="/admin/owner/profile">&#x1F464; My Profile</a></li>
            </ul>
        </aside>
        <div class="dashboard-main">
            <h1 style="font-size:1.5rem;margin-bottom:24px;">Manage Tutors</h1>

            <div class="card" style="padding:24px;margin-bottom:24px;background:var(--yellow-50);border:2px solid var(--yellow-200);">
                <h3 style="font-size:1.1rem;margin-bottom:16px;">&#x1F517; Send Tutor Invite Link</h3>
                <p style="color:var(--gray-600);font-size:0.9rem;margin-bottom:16px;">Generate a secret signup link. They create their own account and password. Expires in 7 days.</p>
                <form action="/admin/owner/tutor-invite" method="POST" style="display:flex;gap:12px;flex-wrap:wrap;align-items:end;"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-group" style="margin:0;flex:1;min-width:200px;">
                        <label>Email (optional, to auto-send)</label>
                        <input type="email" name="email" class="form-control" placeholder="tutor@email.com">
                    </div>
                    <div class="form-group" style="margin:0;flex:1;min-width:200px;">
                        <label>Subjects</label>
                        <select name="subjects_for_invite" class="form-control" multiple style="min-height:80px;">
                            <% subjectOptions.forEach(s => { %>
                            <option value="<%= s %>"><%= s %></option>
                            <% }); %>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-secondary">Generate Link</button>
                </form>
            </div>

            <% if (invites && invites.length > 0) { %>
            <div class="card" style="padding:24px;margin-bottom:24px;">
                <h3 style="font-size:1.1rem;margin-bottom:12px;">Active Invite Links</h3>
                <% invites.forEach(inv => { %>
                <div style="padding:12px 0;border-bottom:1px solid var(--gray-100);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
                    <div>
                        <p class="invite-link-text" style="font-family:monospace;font-size:0.85rem;color:var(--blue-600);word-break:break-all;"><%= siteUrl %>/tutor-signup/<%= inv.token %></p>
                        <p style="font-size:0.8rem;color:var(--gray-400);"><%= inv.email || 'No email' %> &middot; Expires: <%= new Date(inv.expires_at).toLocaleDateString() %></p>
                    </div>
                    <button class="btn btn-outline btn-sm copy-link-btn" data-link="<%= siteUrl %>/tutor-signup/<%= inv.token %>">Copy Link</button>
                </div>
                <% }); %>
            </div>
            <% } %>

            <div class="table-wrapper">
                <table>
                    <thead><tr><th>Name</th><th>Email</th><th>Subjects</th><th>Status</th><th>Actions</th></tr></thead>
                    <tbody>
                        <% if (tutors && tutors.length > 0) { %>
                            <% tutors.forEach(t => { %>
                            <tr>
                                <td><strong><%= t.first_name %> <%= t.last_name %></strong><% if (t.tagline) { %><br><span style="color:var(--gray-400);font-size:0.8rem;"><%= t.tagline %></span><% } %></td>
                                <td><%= t.email %></td>
                                <td><% (t.subjects || []).forEach(s => { %><span class="subject-tag"><%= s %></span> <% }); %></td>
                                <td><span class="badge-status <%= t.approved ? 'badge-active' : 'badge-pending' %>"><%= t.approved ? 'Approved' : 'Pending' %></span></td>
                                <td style="display:flex;gap:6px;flex-wrap:wrap;">
                                    <% if (!t.approved) { %><form action="/admin/owner/tutors/<%= t.id %>/approve" method="POST"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn btn-sm" style="background:var(--green-500);color:white;font-size:0.8rem;">Approve</button></form><% } %>
                                    <a href="/admin/owner/notes/<%= t.id %>" class="btn btn-outline btn-sm" style="font-size:0.8rem;">Notes</a>
                                </td>
                            </tr>
                            <% }); %>
                        <% } else { %><tr><td colspan="5" style="text-align:center;color:var(--gray-400);">No tutors yet.</td></tr><% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<script>
// Copy link buttons
document.querySelectorAll('.copy-link-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        const link = btn.dataset.link;
        navigator.clipboard.writeText(link).then(() => {
            btn.textContent = 'Copied!';
            setTimeout(() => { btn.textContent = 'Copy Link'; }, 2000);
        }).catch(() => {
            // Fallback for HTTP (non-HTTPS)
            const ta = document.createElement('textarea');
            ta.value = link;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            btn.textContent = 'Copied!';
            setTimeout(() => { btn.textContent = 'Copy Link'; }, 2000);
        });
    });
});
</script>

<%- include('../partials/footer') %>

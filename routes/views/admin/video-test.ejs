<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <section class="section" style="padding-top:32px;">
        <div class="container" style="max-width:700px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                <h1 style="font-size:1.5rem;">Test Video Call</h1>
                <a href="/admin/owner" class="btn btn-outline btn-sm">&larr; Dashboard</a>
            </div>
            <div class="card" style="padding:48px;text-align:center;">
                <div style="font-size:4rem;margin-bottom:16px;">&#x1F4F9;</div>
                <h2 style="font-size:1.5rem;margin-bottom:12px;">Test Room Ready</h2>
                <p style="color:var(--gray-500);margin-bottom:32px;">Open this on two devices or browsers to test. No time limit, no signups needed.</p>
                <a href="https://meet.jit.si/<%= roomId %>#userInfo.displayName=%22<%= encodeURIComponent(userName) %>%22" target="_blank" rel="noopener" class="btn btn-primary btn-lg" style="font-size:1.2rem;padding:18px 48px;">
                    Join Video Call
                </a>
                <div style="margin-top:24px;padding:16px;background:var(--gray-50);border-radius:12px;">
                    <p style="font-size:0.8rem;color:var(--gray-400);margin-bottom:8px;font-weight:600;">Room link for second device:</p>
                    <code style="font-size:0.85rem;color:var(--blue-600);word-break:break-all;">https://meet.jit.si/<%= roomId %></code>
                </div>
            </div>
        </div>
    </section>
</main>
<%- include('../partials/footer') %>

<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <div class="dashboard-grid">
        <aside class="dashboard-sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/owner">&#x1F3E0; Dashboard</a></li>
                <li><a href="/admin/owner/calendar">&#x1F4C5; Calendar</a></li>
                <li><a href="/admin/owner/tutors">&#x1F468;&#x200D;&#x1F3EB; Tutors</a></li>
                <li><a href="/admin/owner/students">&#x1F393; Students</a></li>
                <li><a href="/admin/owner/blog" class="active">&#x1F4DD; Blog</a></li>
                <li><a href="/admin/owner/referrals">&#x1F381; Referrals</a></li>
                <li><a href="/admin/owner/settings">&#x2699;&#xFE0F; Settings</a></li>
                <li><a href="/admin/owner/profile">&#x1F464; My Profile</a></li>
            </ul>
        </aside>
        <div class="dashboard-main">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                <h1 style="font-size:1.5rem;">Blog Posts</h1>
                <a href="/admin/owner/blog/new" class="btn btn-primary btn-sm">New Post</a>
            </div>
            <% if (posts && posts.length > 0) { %>
                <% posts.forEach(p => { %>
                <div class="card" style="margin-bottom:12px;padding:20px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
                        <div>
                            <h4><%= p.title %></h4>
                            <p style="color:var(--gray-500);font-size:0.85rem;"><span class="badge-status <%= p.is_published ? 'badge-active' : 'badge-pending' %>"><%= p.is_published ? 'Published' : 'Draft' %></span> &middot; <%= new Date(p.created_at).toLocaleDateString() %></p>
                        </div>
                        <div style="display:flex;gap:8px;">
                            <a href="/admin/owner/blog/<%= p.id %>/edit" class="btn btn-outline btn-sm">Edit</a>
                            <% if (p.is_published) { %><a href="/blog/<%= p.slug %>" class="btn btn-outline btn-sm" target="_blank">View</a><% } %>
                            <form action="/admin/owner/blog/<%= p.id %>/delete" method="POST" onsubmit="return confirm('Delete this post?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn btn-sm" style="background:var(--red-500);color:white;">Delete</button></form>
                        </div>
                    </div>
                </div>
                <% }); %>
            <% } else { %>
                <div class="card" style="padding:40px;text-align:center;"><p style="color:var(--gray-400);">No blog posts yet. <a href="/admin/owner/blog/new">Write your first one!</a></p></div>
            <% } %>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>

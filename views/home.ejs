<%- include('partials/header') %>
<%- include('partials/nav') %>
<main id="main-content">
    <section class="hero" style="padding:120px 0 100px;">
        <div class="container">
            <div style="max-width:720px;">
                <h1 style="font-size:3.75rem;">Where <span class="text-yellow">Bright</span> Futures<br>Begin with <span class="text-blue">Great</span> Tutors</h1>
                <p style="font-size:1.25rem;margin:24px 0 32px;">Personalized learning that actually works. Our expert tutors help students build confidence, master subjects, and fall in love with learning. Plus, a portion of our proceeds go to support children's education charities.</p>
                <div class="hero-buttons">
                    <a href="/consultation" class="btn btn-primary btn-lg">Book a Free Consultation</a>
                    <a href="/tutors" class="btn btn-outline btn-lg">Meet Our Tutors</a>
                </div>
            </div>
        </div>
    </section>

    <section class="stats-bar" aria-label="Our impact in numbers">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item"><h3><%= (stats && stats.stat_satisfaction) || '97%' %></h3><p><%= (stats && stats.stat_satisfaction_label) || 'Student Satisfaction' %></p></div>
                <div class="stat-item"><h3><%= (stats && stats.stat_students) || '500+' %></h3><p><%= (stats && stats.stat_students_label) || 'Students Helped' %></p></div>
                <div class="stat-item"><h3><%= (stats && stats.stat_tutors) || '50+' %></h3><p><%= (stats && stats.stat_tutors_label) || 'Expert Tutors' %></p></div>
                <div class="stat-item"><h3><%= (stats && stats.stat_improvement) || '92%' %></h3><p><%= (stats && stats.stat_improvement_label) || 'Grade Improvement' %></p></div>
            </div>
        </div>
    </section>

    <section class="section" aria-labelledby="services-heading">
        <div class="container">
            <div class="section-header">
                <span class="section-badge">What We Offer</span>
                <h2 id="services-heading">Learning Made Fun and Effective</h2>
                <p>From one-on-one sessions to group learning, we have the right solution for every student.</p>
            </div>
            <div class="services-grid">
                <div class="card service-card" style="border-left:4px solid var(--blue-500);"><h3>One-on-One Tutoring</h3><p>Personalized attention tailored to your child's unique learning style and pace.</p></div>
                <div class="card service-card" style="border-left:4px solid var(--yellow-400);"><h3>Group Sessions</h3><p>Learn together with peers in small, interactive group sessions with collaborative learning.</p></div>
                <div class="card service-card" style="border-left:4px solid var(--blue-400);"><h3>Online Learning</h3><p>Access expert tutoring from anywhere. No extra software or signups needed.</p></div>
                <div class="card service-card" style="border-left:4px solid var(--orange-500);"><h3>Progress Tracking</h3><p>Detailed report cards, session notes, and regular check-ins every 3 months.</p></div>
            </div>
            <div style="text-align:center;margin-top:40px;">
                <a href="/services" class="btn btn-primary">Explore All Services</a>
            </div>
        </div>
    </section>

    <section class="carousel-section" aria-labelledby="carousel-heading">
        <div class="container">
            <div class="section-header">
                <span class="section-badge">Our Amazing Team</span>
                <h2 id="carousel-heading">Meet Our Star Tutors</h2>
                <p>Handpicked educators passionate about making a difference.</p>
            </div>
        </div>
        <div class="carousel-track-wrapper">
            <div class="carousel-track">
                <% if (tutors && tutors.length > 0) { %>
                    <% tutors.forEach(function(tutor) { %>
                    <a href="/tutors" class="carousel-card" tabindex="0" style="text-decoration:none;color:inherit;">
                        <div class="carousel-card-header">
                            <div class="carousel-avatar"><% if (tutor.profile_picture) { %><img src="<%= tutor.profile_picture %>" alt="" loading="lazy" width="56" height="56"><% } else { %><%= tutor.first_name.charAt(0) %><%= tutor.last_name.charAt(0) %><% } %></div>
                            <div><h4><%= tutor.first_name %> <%= tutor.last_name %></h4><span class="subjects"><%= (tutor.subjects || []).join(', ') %></span></div>
                        </div>
                        <p><%= tutor.carousel_description || tutor.tagline || tutor.bio || 'Passionate about helping students succeed!' %></p>
                    </a>
                    <% }); %>
                <% } else { %>
                    <div class="carousel-card"><p style="color:var(--gray-400);text-align:center;">Our tutor profiles are being set up. Check back soon!</p></div>
                <% } %>
            </div>
        </div>
    </section>

    <section class="section" aria-labelledby="why-heading">
        <div class="container">
            <div class="section-header">
                <span class="section-badge">Why <%= siteName %>?</span>
                <h2 id="why-heading">What Makes Us Different</h2>
            </div>
            <div class="services-grid">
                <div class="card" style="border-top:3px solid var(--yellow-400);padding:28px;"><h3 style="font-size:1.1rem;margin-bottom:8px;">Top Quality Tutors</h3><p style="color:var(--gray-500);">Every tutor goes through our rigorous vetting process. We only accept the best so your child gets the best.</p></div>
                <div class="card" style="border-top:3px solid var(--blue-500);padding:28px;"><h3 style="font-size:1.1rem;margin-bottom:8px;">Flexible Scheduling</h3><p style="color:var(--gray-500);">Our interactive calendar makes booking easy. See when tutors are available and manage everything in one place.</p></div>
                <div class="card" style="border-top:3px solid var(--orange-500);padding:28px;"><h3 style="font-size:1.1rem;margin-bottom:8px;">Giving Back</h3><p style="color:var(--gray-500);">A portion of our proceeds goes directly to <%= charityName %>. Invest in your child and help others too.</p></div>
                <div class="card" style="border-top:3px solid var(--blue-400);padding:28px;"><h3 style="font-size:1.1rem;margin-bottom:8px;">Direct Communication</h3><p style="color:var(--gray-500);">Message tutors directly. File complaints, ask questions, or just check in. Parents stay in the loop.</p></div>
            </div>
        </div>
    </section>

    <section class="section" style="background:linear-gradient(135deg,var(--blue-700),var(--blue-900));text-align:center;color:white;">
        <div class="container">
            <h2 style="color:white;font-size:2.5rem;margin-bottom:16px;">Ready to Help Your Child Shine?</h2>
            <p style="color:var(--blue-200);font-size:1.2rem;max-width:600px;margin:0 auto 32px;">Book a free consultation call and discover how we can transform your child's learning experience.</p>
            <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
                <a href="/consultation" class="btn btn-secondary btn-lg">Book Free Consultation</a>
                <a href="/auth/register" class="btn btn-lg" style="background:rgba(255,255,255,0.15);color:white;border:2px solid rgba(255,255,255,0.3);">Sign Up Today</a>
            </div>
        </div>
    </section>
</main>
<%- include('partials/footer') %>

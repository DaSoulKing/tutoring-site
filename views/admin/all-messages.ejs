<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <div class="dashboard-grid">
        <aside class="dashboard-sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/owner">Dashboard</a></li>
                <li><a href="/admin/owner/calendar">Calendar</a></li>
                <li><a href="/admin/owner/availability">Availability</a></li>
                <li><a href="/admin/owner/tutors">Tutors</a></li>
                <li><a href="/admin/owner/students">Students</a></li>
                <li><a href="/admin/owner/sheets">Session Sheets</a></li>
                <li><a href="/admin/owner/messages" class="active">Messages</a></li>
                <li><a href="/admin/owner/audit-log">Audit Log</a></li>
                <li><a href="/admin/owner/blog">Blog</a></li>
                <li><a href="/admin/owner/referrals">Referrals</a></li>
                <li><a href="/admin/owner/settings">Settings</a></li>
                <li><a href="/admin/owner/profile">My Profile</a></li>
            </ul>
        </aside>
        <div class="dashboard-main">
            <h1 style="font-size:1.5rem;margin-bottom:8px;">All Messages</h1>
            <p style="color:var(--gray-500);font-size:0.85rem;margin-bottom:16px;">All tutors and students are informed that messages may be monitored for safety and quality assurance.</p>

            <!-- Filters -->
            <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:24px;">
                <form style="display:flex;gap:8px;flex-wrap:wrap;align-items:end;flex:1;">
                    <div class="form-group" style="margin:0;min-width:180px;">
                        <label style="font-size:0.8rem;">Filter by person</label>
                        <select name="person" class="form-control" style="padding:8px 12px;" onchange="this.form.submit()">
                            <option value="">All People</option>
                            <% people.forEach(function(p) { %>
                            <option value="<%= p.id %>" <%= currentPerson == p.id ? 'selected' : '' %>><%= p.first_name %> <%= p.last_name %> (<%= p.role %>)</option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="form-group" style="margin:0;min-width:200px;">
                        <label style="font-size:0.8rem;">Search messages</label>
                        <input type="text" name="search" class="form-control" style="padding:8px 12px;" placeholder="Search..." value="<%= currentSearch %>">
                    </div>
                    <button type="submit" class="btn btn-outline btn-sm">Filter</button>
                    <% if (currentPerson || currentSearch) { %><a href="/admin/owner/messages" class="btn btn-sm" style="color:var(--gray-500);">Clear</a><% } %>
                </form>
            </div>

            <% if (messages.length === 0) { %>
            <div class="card" style="padding:32px;text-align:center;"><p style="color:var(--gray-400);">No messages found.</p></div>
            <% } else { %>
            <p style="color:var(--gray-400);font-size:0.8rem;margin-bottom:12px;">Showing <%= messages.length %> messages</p>
            <div style="display:flex;flex-direction:column;gap:8px;">
                <% messages.forEach(function(m) { %>
                <div class="card" style="padding:14px;">
                    <div style="display:flex;justify-content:space-between;align-items:start;gap:12px;">
                        <div style="flex:1;">
                            <p style="font-size:0.8rem;color:var(--gray-400);margin-bottom:4px;">
                                <strong style="color:var(--blue-600);"><%= m.sender_first %> <%= m.sender_last %></strong>
                                <span style="color:var(--gray-300);font-size:0.75rem;">(<%= m.sender_role %>)</span>
                                &rarr; <strong><%= m.receiver_first %> <%= m.receiver_last %></strong>
                                <span style="color:var(--gray-300);font-size:0.75rem;">(<%= m.receiver_role %>)</span>
                                &middot; <%= new Date(m.created_at).toLocaleString() %>
                            </p>
                            <p style="font-size:0.9rem;color:var(--gray-700);white-space:pre-wrap;"><%= m.body %></p>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } %>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>

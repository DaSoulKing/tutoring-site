<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <section class="section" style="padding-top:32px;">
        <div class="container" style="max-width:800px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                <h1 style="font-size:1.5rem;"><%= post ? 'Edit Post' : 'New Blog Post' %></h1>
                <a href="/admin/owner/blog" class="btn btn-outline btn-sm">&larr; All Posts</a>
            </div>
            <div class="card" style="padding:32px;">
                <form action="<%= post ? '/admin/owner/blog/' + post.id : '/admin/owner/blog' %>" method="POST"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-group"><label for="title">Title <span class="required">*</span></label><input type="text" id="title" name="title" class="form-control" required value="<%= post ? post.title : '' %>"></div>
                    <div class="form-group"><label for="excerpt">Excerpt</label><input type="text" id="excerpt" name="excerpt" class="form-control" value="<%= post ? post.excerpt || '' : '' %>" placeholder="Short summary..."></div>
                    <div class="form-group"><label for="content">Content <span class="required">*</span></label><textarea id="content" name="content" class="form-control" rows="15" required><%= post ? post.content : '' %></textarea></div>
                    <div class="form-group"><label><input type="checkbox" name="is_published" <%= post && post.is_published ? 'checked' : '' %>> Publish now</label></div>
                    <button type="submit" class="btn btn-primary"><%= post ? 'Update Post' : 'Create Post' %></button>
                </form>
            </div>
        </div>
    </section>
</main>
<%- include('../partials/footer') %>

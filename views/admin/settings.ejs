<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <div class="dashboard-grid">
        <aside class="dashboard-sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/owner">>Dashboard</a>#x1F3E0; Dashboard</a></li>
                <li><a href="/admin/owner/calendar">>Calendar</a>#x1F4C5; Calendar</a></li>
                <li><a href="/admin/owner/availability">>Availability</a>#x1F552; Availability</a></li>
                <li><a href="/admin/owner/tutors">>Tutors</a>#x1F468;>Tutors</a>#x200D;>Tutors</a>#x1F3EB; Tutors</a></li>
                <li><a href="/admin/owner/students">>Students</a>#x1F393; Students</a></li>
                <li><a href="/admin/owner/sheets">>Session Sheets</a>#x1F4CB; Session Sheets</a></li>
                <li><a href="/admin/owner/messages">>Messages</a>#x1F4AC; Messages</a></li>
                <li><a href="/admin/owner/audit-log">>Audit Log</a>#x1F4DC; Audit Log</a></li>
                <li><a href="/admin/owner/blog">>Blog</a>#x1F4DD; Blog</a></li>
                <li><a href="/admin/owner/referrals">>Referrals</a>#x1F381; Referrals</a></li>
                <li><a href="/admin/owner/settings" class="active">>Settings</a>#x2699;>Settings</a>#xFE0F; Settings</a></li>
                <li><a href="/admin/owner/profile">>My Profile</a>#x1F464; My Profile</a></li>
            </ul>
        </aside>
        <div class="dashboard-main">
            <h1 style="font-size:1.5rem;margin-bottom:24px;">Site Settings</h1>

            <div class="card" style="padding:24px;margin-bottom:24px;">
                <h3 style="font-size:1.1rem;margin-bottom:16px;">Homepage Stats</h3>
                <p style="color:var(--gray-500);margin-bottom:20px;">These numbers appear in the stats bar on the homepage. Update them to reflect your actual numbers.</p>
                <form action="/admin/owner/settings" method="POST"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div style="display:grid;grid-template-columns:1fr 2fr;gap:16px;margin-bottom:16px;">
                        <div class="form-group" style="margin:0;">
                            <label>Stat 1 Value</label>
                            <input type="text" name="stat_satisfaction" class="form-control" value="<%= settings.stat_satisfaction || '97%' %>" placeholder="e.g., 97%">
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label>Stat 1 Label</label>
                            <input type="text" name="stat_satisfaction_label" class="form-control" value="<%= settings.stat_satisfaction_label || 'Student Satisfaction' %>">
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 2fr;gap:16px;margin-bottom:16px;">
                        <div class="form-group" style="margin:0;">
                            <label>Stat 2 Value</label>
                            <input type="text" name="stat_students" class="form-control" value="<%= settings.stat_students || '500+' %>">
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label>Stat 2 Label</label>
                            <input type="text" name="stat_students_label" class="form-control" value="<%= settings.stat_students_label || 'Students Helped' %>">
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 2fr;gap:16px;margin-bottom:16px;">
                        <div class="form-group" style="margin:0;">
                            <label>Stat 3 Value</label>
                            <input type="text" name="stat_tutors" class="form-control" value="<%= settings.stat_tutors || '50+' %>">
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label>Stat 3 Label</label>
                            <input type="text" name="stat_tutors_label" class="form-control" value="<%= settings.stat_tutors_label || 'Expert Tutors' %>">
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 2fr;gap:16px;margin-bottom:20px;">
                        <div class="form-group" style="margin:0;">
                            <label>Stat 4 Value</label>
                            <input type="text" name="stat_improvement" class="form-control" value="<%= settings.stat_improvement || '92%' %>">
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label>Stat 4 Label</label>
                            <input type="text" name="stat_improvement_label" class="form-control" value="<%= settings.stat_improvement_label || 'Grade Improvement' %>">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Save Stats</button>
                </form>
            </div>

            <div class="card" style="padding:24px;">
                <h3 style="font-size:1.1rem;margin-bottom:12px;">Other Settings</h3>
                <p style="color:var(--gray-500);margin-bottom:16px;">These are configured via Railway environment variables:</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div style="padding:12px;background:var(--gray-50);border-radius:8px;"><strong>Site Name:</strong> <%= siteName %></div>
                    <div style="padding:12px;background:var(--gray-50);border-radius:8px;"><strong>Charity:</strong> <%= charityName %></div>
                    <div style="padding:12px;background:var(--gray-50);border-radius:8px;"><strong>Site URL:</strong> <%= siteUrl %></div>
                    <div style="padding:12px;background:var(--gray-50);border-radius:8px;"><strong>Email:</strong> <%= process.env.RESEND_API_KEY ? 'Resend API' : (process.env.SMTP_HOST ? 'SMTP' : 'Not configured') %></div>
                </div>
                <p style="color:var(--gray-400);font-size:0.85rem;margin-top:12px;">To change these, update the environment variables in your Railway dashboard and redeploy.</p>
            </div>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>

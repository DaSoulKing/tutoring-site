<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <div class="dashboard-grid">
        <aside class="dashboard-sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/owner">>Dashboard</a>#x1F3E0; Dashboard</a></li>
                <li><a href="/admin/owner/calendar">>Calendar</a>#x1F4C5; Calendar</a></li>
                <li><a href="/admin/owner/availability">>Availability</a>#x1F552; Availability</a></li>
                <li><a href="/admin/owner/tutors">>Tutors</a>#x1F468;>Tutors</a>#x200D;>Tutors</a>#x1F3EB; Tutors</a></li>
                <li><a href="/admin/owner/students">>Students</a>#x1F393; Students</a></li>
                <li><a href="/admin/owner/sheets">>Session Sheets</a>#x1F4CB; Session Sheets</a></li>
                <li><a href="/admin/owner/messages">>Messages</a>#x1F4AC; Messages</a></li>
                <li><a href="/admin/owner/audit-log" class="active">>Audit Log</a>#x1F4DC; Audit Log</a></li>
                <li><a href="/admin/owner/blog">>Blog</a>#x1F4DD; Blog</a></li>
                <li><a href="/admin/owner/referrals">>Referrals</a>#x1F381; Referrals</a></li>
                <li><a href="/admin/owner/settings">>Settings</a>#x2699;>Settings</a>#xFE0F; Settings</a></li>
                <li><a href="/admin/owner/profile">>My Profile</a>#x1F464; My Profile</a></li>
            </ul>
        </aside>
        <div class="dashboard-main">
            <h1 style="font-size:1.5rem;margin-bottom:8px;">Audit Log</h1>
            <p style="color:var(--gray-500);margin-bottom:24px;">Every schedule change, attendance update, and account action is recorded here.</p>

            <% if (logs.length === 0) { %>
            <div class="card" style="padding:32px;text-align:center;"><p style="color:var(--gray-400);">No activity logged yet.</p></div>
            <% } else { %>
            <div class="table-wrapper">
                <table>
                    <thead><tr><th>Time</th><th>User</th><th>Action</th><th>Details</th></tr></thead>
                    <tbody>
                        <% logs.forEach(function(l) { %>
                        <tr>
                            <td style="white-space:nowrap;font-size:0.8rem;"><%= new Date(l.created_at).toLocaleString() %></td>
                            <td><%= l.first_name ? (l.first_name + ' ' + l.last_name) : 'System' %></td>
                            <td><span class="badge-status badge-<%= l.action.includes('delete') ? 'cancelled' : (l.action.includes('approve') || l.action.includes('verify') ? 'confirmed' : 'pending') %>"><%= l.action.replace(/_/g, ' ') %></span></td>
                            <td style="font-size:0.85rem;color:var(--gray-600);max-width:400px;word-break:break-word;"><%= l.details || '' %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>

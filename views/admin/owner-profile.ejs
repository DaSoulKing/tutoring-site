<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <div class="dashboard-grid">
        <aside class="dashboard-sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/owner">>Dashboard</a>#x1F3E0; Dashboard</a></li>
                <li><a href="/admin/owner/calendar">>Calendar</a>#x1F4C5; Calendar</a></li>
                <li><a href="/admin/owner/availability">>Availability</a>#x1F552; Availability</a></li>
                <li><a href="/admin/owner/tutors">>Tutors</a>#x1F468;>Tutors</a>#x200D;>Tutors</a>#x1F3EB; Tutors</a></li>
                <li><a href="/admin/owner/students">>Students</a>#x1F393; Students</a></li>
                <li><a href="/admin/owner/sheets">>Session Sheets</a>#x1F4CB; Session Sheets</a></li>
                <li><a href="/admin/owner/messages">>Messages</a>#x1F4AC; Messages</a></li>
                <li><a href="/admin/owner/audit-log">>Audit Log</a>#x1F4DC; Audit Log</a></li>
                <li><a href="/admin/owner/blog">>Blog</a>#x1F4DD; Blog</a></li>
                <li><a href="/admin/owner/referrals">>Referrals</a>#x1F381; Referrals</a></li>
                <li><a href="/admin/owner/settings">>Settings</a>#x2699;>Settings</a>#xFE0F; Settings</a></li>
                <li><a href="/admin/owner/profile" class="active">>My Profile</a>#x1F464; My Profile</a></li>
            </ul>
        </aside>
        <div class="dashboard-main">
            <h1 style="font-size:1.5rem;margin-bottom:24px;">My Profile</h1>

            <div class="card" style="padding:32px;max-width:600px;">
                <!-- Current photo -->
                <div style="text-align:center;margin-bottom:24px;">
                    <div style="width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,var(--blue-400),var(--blue-600));margin:0 auto;display:flex;align-items:center;justify-content:center;color:white;font-family:var(--font-display);font-size:2.5rem;font-weight:700;overflow:hidden;">
                        <% if (owner.profile_picture) { %>
                            <img src="<%= owner.profile_picture %>" alt="" width="120" height="120" style="object-fit:cover;">
                        <% } else { %>
                            <%= owner.first_name.charAt(0) %><%= owner.last_name.charAt(0) %>
                        <% } %>
                    </div>
                    <p style="color:var(--gray-400);font-size:0.85rem;margin-top:8px;"><%= owner.email %></p>
                </div>

                <form action="/admin/owner/profile?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="first_name">First Name</label>
                            <input type="text" id="first_name" name="first_name" class="form-control" value="<%= owner.first_name %>" required>
                        </div>
                        <div class="form-group">
                            <label for="last_name">Last Name</label>
                            <input type="text" id="last_name" name="last_name" class="form-control" value="<%= owner.last_name %>" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="phone">Phone</label>
                        <input type="tel" id="phone" name="phone" class="form-control" value="<%= owner.phone || '' %>">
                    </div>
                    <div class="form-group">
                        <label for="profile_picture">Profile Picture</label>
                        <input type="file" id="profile_picture" name="profile_picture" class="form-control" accept="image/*">
                        <p style="font-size:0.8rem;color:var(--gray-400);margin-top:4px;">This photo shows on the About Us page. JPG or PNG, max 5MB.</p>
                    </div>
                    <button type="submit" class="btn btn-primary">Update Profile</button>
                </form>
            </div>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>

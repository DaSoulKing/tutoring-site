<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<main id="main-content">
    <div class="dashboard-grid">
        <aside class="dashboard-sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/owner">&#x1F3E0; Dashboard</a></li>
                <li><a href="/admin/owner/calendar">&#x1F4C5; Calendar</a></li>
                <li><a href="/admin/owner/tutors" class="active">&#x1F468;&#x200D;&#x1F3EB; Manage Tutors</a></li>
                <li><a href="/admin/owner/students">&#x1F393; Manage Students</a></li>
            </ul>
        </aside>

        <div class="dashboard-main">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                <h1 style="font-size:1.5rem;">Manage Tutors</h1>
            </div>

            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr><th>Name</th><th>Email</th><th>Subjects</th><th>Status</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% if (tutors && tutors.length > 0) { %>
                            <% tutors.forEach(t => { %>
                            <tr>
                                <td><strong><%= t.first_name %> <%= t.last_name %></strong></td>
                                <td><%= t.email %></td>
                                <td>
                                    <% (t.subjects || []).forEach(s => { %>
                                    <span class="subject-tag"><%= s %></span>
                                    <% }); %>
                                </td>
                                <td>
                                    <span class="badge-status <%= t.approved ? 'badge-active' : 'badge-pending' %>"><%= t.approved ? 'Approved' : 'Pending' %></span>
                                    <% if (!t.is_active) { %><span class="badge-status badge-cancelled">Inactive</span><% } %>
                                </td>
                                <td>
                                    <a href="/admin/owner/notes/<%= t.id %>" class="btn btn-outline btn-sm" style="font-size:0.8rem;">Notes</a>
                                </td>
                            </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="5" style="text-align:center;color:var(--gray-400);">No tutors found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>

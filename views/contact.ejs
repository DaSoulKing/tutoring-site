<%- include('partials/header') %>
<%- include('partials/nav') %>

<main id="main-content">
    <section class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-badge">Get In Touch</span>
                <h2>Contact Us</h2>
                <p>Have a question, concern, or just want to say hello? We would love to hear from you.</p>
            </div>

            <div class="two-col-layout" style="display:grid;grid-template-columns:1fr 1fr;gap:48px;max-width:1000px;margin:0 auto;">
                <div>
                    <form action="/contact" method="POST" data-validate><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="form-group">
                            <label for="name">Full Name <span class="required">*</span></label>
                            <input type="text" id="name" name="name" class="form-control" required placeholder="Your full name">
                        </div>
                        <div class="form-group">
                            <label for="email">Email <span class="required">*</span></label>
                            <input type="email" id="email" name="email" class="form-control" required placeholder="your@email.com">
                        </div>
                        <div class="form-group">
                            <label for="phone">Phone (Optional)</label>
                            <input type="tel" id="phone" name="phone" class="form-control" placeholder="(555) 123-4567">
                        </div>
                        <div class="form-group">
                            <label for="inquiry_type">What is this about? <span class="required">*</span></label>
                            <select id="inquiry_type" name="inquiry_type" class="form-control" required>
                                <option value="general">General Inquiry</option>
                                <option value="support">Support</option>
                                <option value="complaint">Complaint</option>
                                <option value="feedback">Feedback</option>
                                <option value="inquiry">Partnership Inquiry</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="subject">Subject <span class="required">*</span></label>
                            <input type="text" id="subject" name="subject" class="form-control" required placeholder="What can we help with?">
                        </div>
                        <div class="form-group">
                            <label for="message">Message <span class="required">*</span></label>
                            <textarea id="message" name="message" class="form-control" required placeholder="Tell us more..."></textarea>
                        </div>

                        <% if (recaptchaSiteKey) { %>
                        <div class="form-group">
                            <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
                        </div>
                        <% } %>

                        <button type="submit" class="btn btn-primary btn-block">Send Message</button>
                    </form>
                </div>

                <div>
                    <div class="card" style="margin-bottom:24px;">
                        <div class="card-header">
                            <div class="card-icon blue" aria-hidden="true">&#x1F4E7;</div>
                            <div>
                                <h3 style="font-size:1.1rem;">Email Us</h3>
                                <p style="color:var(--gray-500);"><%= process.env.OWNER_EMAIL || 'Contact us via the form' %></p>
                            </div>
                        </div>
                    </div>
                    <div class="card" style="margin-bottom:24px;">
                        <div class="card-header">
                            <div class="card-icon yellow" aria-hidden="true">&#x1F4DE;</div>
                            <div>
                                <h3 style="font-size:1.1rem;">Call Us</h3>
                                <p style="color:var(--gray-500);"><%= process.env.BUSINESS_PHONE || "Contact us" %></p>
                            </div>
                        </div>
                    </div>
                    <div class="card" style="margin-bottom:24px;">
                        <div class="card-header">
                            <div class="card-icon blue" aria-hidden="true">&#x23F0;</div>
                            <div>
                                <h3 style="font-size:1.1rem;">Response Time</h3>
                                <p style="color:var(--gray-500);">Within 24 hours</p>
                            </div>
                        </div>
                    </div>

                    <div class="card" style="background:var(--blue-50);border:2px solid var(--blue-200);">
                        <h3 style="font-size:1.1rem;margin-bottom:12px;">For Parents & Students</h3>
                        <p style="color:var(--gray-600);line-height:1.7;margin-bottom:16px;">Already a <%= siteName %> member? You can message your tutor directly or submit inquiries through your dashboard for faster responses.</p>
                        <a href="/auth/login" class="btn btn-primary btn-sm">Go to Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>

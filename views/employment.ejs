<%- include('partials/header') %>
<%- include('partials/nav') %>

<main id="main-content">
    <section class="section" style="background:linear-gradient(135deg, var(--yellow-50), var(--white));">
        <div class="container">
            <div class="section-header">
                <span class="section-badge">Join Our Team</span>
                <h2>Become a <%= siteName %> Tutor</h2>
                <p>Love teaching? Want to make a difference? Apply to join our team of expert educators.</p>
            </div>

            <div style="max-width:700px;margin:0 auto;">
                <div class="card" style="padding:40px;">
                    <form action="/employment?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" data-validate>
                        <div class="form-group">
                            <label for="applicant_type">I am applying as <span class="required">*</span></label>
                            <select id="applicant_type" name="applicant_type" class="form-control" required>
                                <option value="tutor">Tutor</option>
                                <option value="student">Student (looking for tutoring)</option>
                            </select>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="first_name">First Name <span class="required">*</span></label>
                                <input type="text" id="first_name" name="first_name" class="form-control" required>
                            </div>
                            <div class="form-group">
                                <label for="last_name">Last Name <span class="required">*</span></label>
                                <input type="text" id="last_name" name="last_name" class="form-control" required>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="email">Email <span class="required">*</span></label>
                                <input type="email" id="email" name="email" class="form-control" required>
                            </div>
                            <div class="form-group">
                                <label for="phone">Phone</label>
                                <input type="tel" id="phone" name="phone" class="form-control">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="subjects">Subjects (comma separated) <span class="required">*</span></label>
                            <input type="text" id="subjects" name="subjects" class="form-control" required placeholder="Math, Science, English...">
                        </div>

                        <div class="form-group">
                            <label for="education">Education Background <span class="required">*</span></label>
                            <input type="text" id="education" name="education" class="form-control" required placeholder="Degree, university, certifications...">
                        </div>

                        <div class="form-group">
                            <label for="experience">Teaching Experience</label>
                            <textarea id="experience" name="experience" class="form-control" placeholder="Tell us about your teaching or tutoring experience..."></textarea>
                        </div>

                        <div class="form-group">
                            <label for="availability">Availability</label>
                            <input type="text" id="availability" name="availability" class="form-control" placeholder="e.g., Weekdays 3-7 PM, Weekends 10 AM - 4 PM">
                        </div>

                        <div class="form-group">
                            <label for="why_join">Why do you want to join <%= siteName %>? <span class="required">*</span></label>
                            <textarea id="why_join" name="why_join" class="form-control" required placeholder="Tell us what motivates you..."></textarea>
                        </div>

                        <div class="form-group">
                            <label for="cover_letter">Cover Letter</label>
                            <textarea id="cover_letter" name="cover_letter" class="form-control" placeholder="Optional cover letter..."></textarea>
                        </div>

                        <div class="form-group">
                            <label for="resume">Resume (PDF, DOC, DOCX, max 5MB)</label>
                            <input type="file" id="resume" name="resume" class="form-control" accept=".pdf,.doc,.docx">
                        </div>

                        <% if (recaptchaSiteKey) { %>
                        <div class="form-group">
                            <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
                        </div>
                        <% } %>

                        <button type="submit" class="btn btn-primary btn-block btn-lg">Submit Application</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>

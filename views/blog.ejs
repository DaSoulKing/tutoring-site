<%- include('partials/header') %>
<%- include('partials/nav') %>

<main id="main-content">
    <section class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-badge">Insights & Tips</span>
                <h2>The <%= siteName %> Blog</h2>
                <p>Tips, stories, and insights on education, learning, and helping your child succeed.</p>
            </div>

            <div class="blog-grid">
                <% if (posts && posts.length > 0) { %>
                    <% posts.forEach(post => { %>
                    <a href="/blog/<%= post.slug %>" class="blog-card" style="color:inherit;">
                        <div class="blog-card-image"></div>
                        <div class="blog-card-body">
                            <h3><%= post.title %></h3>
                            <p><%= post.excerpt || post.content.substring(0, 150) + '...' %></p>
                            <div class="blog-card-meta">
                                By <%= post.first_name %> <%= post.last_name %> &middot;
                                <%= new Date(post.published_at || post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                            </div>
                        </div>
                    </a>
                    <% }); %>
                <% } else { %>
                    <div style="grid-column:1/-1;text-align:center;padding:60px 20px;">
                        <p style="font-size:3rem;margin-bottom:16px;" aria-hidden="true"></p>
                        <h3>Blog posts coming soon!</h3>
                        <p style="color:var(--gray-500);margin-top:8px;">We are working on great content for parents and students. Check back soon!</p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>

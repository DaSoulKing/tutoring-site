<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <section class="section">
        <div class="container" style="max-width:520px;">
            <div style="text-align:center;margin-bottom:32px;">
                <h2>Welcome to <%= siteName %>!</h2>
                <p style="color:var(--gray-500);">Create your tutor account to get started.</p>
            </div>
            <div class="card" style="padding:36px;">
                <form action="/tutor-signup/<%= token %>" method="POST" data-validate><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-row">
                        <div class="form-group"><label for="first_name">First Name <span class="required">*</span></label><input type="text" id="first_name" name="first_name" class="form-control" required></div>
                        <div class="form-group"><label for="last_name">Last Name <span class="required">*</span></label><input type="text" id="last_name" name="last_name" class="form-control" required></div>
                    </div>
                    <div class="form-group"><label for="email">Email <span class="required">*</span></label><input type="email" id="email" name="email" class="form-control" required value="<%= invite.email || '' %>"></div>
                    <div class="form-group"><label for="phone">Phone</label><input type="tel" id="phone" name="phone" class="form-control"></div>
                    <div class="form-group"><label for="password">Password <span class="required">*</span> (8+ chars, uppercase, lowercase, number)</label><input type="password" id="password" name="password" class="form-control" required minlength="8"></div>
                    <div class="form-group"><label for="confirm_password">Confirm Password <span class="required">*</span></label><input type="password" id="confirm_password" name="confirm_password" class="form-control" required></div>
                    <div class="form-group">
                        <label>Subjects You Teach <span class="required">*</span></label>
                        <select id="subjects-select" class="form-control" multiple style="min-height:140px;">
                            <% ['Math','Algebra','Geometry','Calculus','Statistics','Science','Biology','Chemistry','Physics','English','Writing','Reading','Literature','History','Social Studies','Geography','French','Spanish','Mandarin','Computer Science','Coding','SAT Prep','ACT Prep','Test Strategy','Study Skills','Art','Music'].forEach(function(s) { %>
                            <option value="<%= s %>"><%= s %></option>
                            <% }); %>
                        </select>
                        <input type="hidden" name="subjects" id="subjects-hidden" value="">
                        <p style="font-size:0.8rem;color:var(--gray-400);margin-top:4px;">Hold Ctrl/Cmd to select multiple</p>
                    </div>
                    <div class="form-group">
                        <label>Grade Levels You're Comfortable Teaching <span class="required">*</span></label>
                        <select id="grades-select" class="form-control" multiple style="min-height:100px;">
                            <option value="K-2">K-2 (Ages 5-8)</option>
                            <option value="3-5">3-5 (Ages 8-11)</option>
                            <option value="6-8">6-8 (Middle School)</option>
                            <option value="9-12">9-12 (High School)</option>
                            <option value="College">College</option>
                            <option value="Adult">Adult</option>
                        </select>
                        <input type="hidden" name="grade_levels" id="grades-hidden" value="">
                        <p style="font-size:0.8rem;color:var(--gray-400);margin-top:4px;">Hold Ctrl/Cmd to select multiple</p>
                    </div>
                    <div class="form-group"><label for="bio">Short Bio</label><textarea id="bio" name="bio" class="form-control" rows="3" placeholder="Tell students about yourself..."></textarea></div>
                    <button type="submit" class="btn btn-primary btn-block btn-lg" id="tutor-signup-btn">Create Tutor Account</button>
                </form>
                <script>
                document.querySelector('form').addEventListener('submit', function() {
                    document.getElementById('subjects-hidden').value = Array.from(document.getElementById('subjects-select').selectedOptions).map(function(o){return o.value}).join(', ');
                    document.getElementById('grades-hidden').value = Array.from(document.getElementById('grades-select').selectedOptions).map(function(o){return o.value}).join(', ');
                });
                </script>
            </div>
        </div>
    </section>
</main>
<%- include('../partials/footer') %>

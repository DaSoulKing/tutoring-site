<%- include('partials/header') %>
<%- include('partials/nav') %>

<main id="main-content">
    <section class="section">
        <div class="container" style="max-width:800px;">
            <a href="/blog" style="color:var(--blue-500);font-weight:600;font-size:0.9rem;">&larr; Back to Blog</a>
            <article style="margin-top:24px;">
                <h1 style="font-size:2.25rem;margin-bottom:12px;"><%= post.title %></h1>
                <div style="color:var(--gray-400);font-size:0.9rem;margin-bottom:32px;">
                    By <%= post.first_name %> <%= post.last_name %> &middot;
                    <%= new Date(post.published_at || post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                </div>
                <div style="color:var(--gray-700);line-height:1.9;font-size:1.05rem;">
                    <%- post.content.replace(/\n/g, '<br>') %>
                </div>
            </article>
        </div>
    </section>
</main>

<%- include('partials/footer') %>

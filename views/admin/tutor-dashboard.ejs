<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<% var subjectOptions = ['Math', 'Algebra', 'Geometry', 'Calculus', 'Statistics', 'Science', 'Biology', 'Chemistry', 'Physics', 'English', 'Writing', 'Reading', 'Literature', 'History', 'Social Studies', 'Geography', 'French', 'Spanish', 'Mandarin', 'Computer Science', 'Coding', 'SAT Prep', 'ACT Prep', 'Test Strategy', 'Study Skills', 'Art', 'Music']; %>

<main id="main-content">
    <div class="dashboard-grid">
        <aside class="dashboard-sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/tutor" class="active">Dashboard</a></li>
                <li><a href="/admin/tutor/calendar">My Calendar</a></li>
                <li><a href="/parent/messages">Messages <% if (unreadCount > 0) { %><span class="badge message-badge"><%= unreadCount %></span><% } %></a></li>
            </ul>
        </aside>
        <div class="dashboard-main">
            <div class="dashboard-welcome"><h1>Tutor Dashboard</h1><p>Welcome, <%= user.firstName %>!</p></div>

            <% if (!profile.approved) { %>
            <div class="alert alert-warning">Your account is pending approval. You can set up your profile and availability while you wait.</div>
            <% } %>

            <!-- UPCOMING SESSIONS (priority - shown first) -->
            <h2 style="font-size:1.25rem;margin-bottom:16px;">Upcoming Sessions</h2>
            <% if (sessions && sessions.length > 0) { %>
                <% sessions.forEach(function(s) { %>
                <div class="card" style="margin-bottom:12px;padding:20px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
                        <div><h4><%= s.student_first %> <%= s.student_last %></h4><p style="color:var(--gray-500);font-size:0.85rem;"><%= s.subject || 'General' %> &middot; <%= new Date(s.booking_date).toLocaleDateString() %> &middot; <%= s.start_time ? s.start_time.substring(0,5) : '' %> - <%= s.end_time ? s.end_time.substring(0,5) : '' %></p></div>
                        <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                            <span class="badge-status badge-<%= s.status %>"><%= s.status %></span>
                            <% if (s.attendance) { %><span class="badge-status badge-<%= s.attendance === 'present' ? 'confirmed' : 'cancelled' %>"><%= s.attendance %></span><% } %>
                            <% if (s.status === 'pending') { %>
                            <form action="/api/bookings/<%= s.id %>/confirm" method="POST" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn btn-sm" style="background:var(--green-500);color:white;">Confirm</button></form>
                            <% } %>
                            <% if (s.status === 'confirmed') { %><a href="/parent/session/<%= s.id %>" class="btn btn-primary btn-sm">Join</a><% } %>
                            <% if (s.status === 'confirmed' && !s.attendance) { %>
                            <form action="/admin/tutor/bookings/<%= s.id %>/attendance" method="POST" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="attendance" value="present"><button type="submit" class="btn btn-sm" style="background:#D1FAE5;color:var(--green-600);font-size:0.75rem;">Present</button></form>
                            <form action="/admin/tutor/bookings/<%= s.id %>/attendance" method="POST" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="attendance" value="absent"><button type="submit" class="btn btn-sm" style="background:#FEE2E2;color:var(--red-600);font-size:0.75rem;">Absent</button></form>
                            <% } %>
                            <a href="/admin/tutor/session-sheet/<%= s.id %>" class="btn btn-outline btn-sm">Sheet</a>
                        </div>
                    </div>
                    <% if (s.status === 'confirmed' || s.status === 'pending') { %>
                    <details style="margin-top:8px;">
                        <summary style="cursor:pointer;font-size:0.8rem;color:var(--blue-600);font-weight:600;">Reschedule</summary>
                        <form action="/admin/tutor/bookings/<%= s.id %>/reschedule" method="POST" style="display:flex;gap:8px;flex-wrap:wrap;align-items:end;margin-top:8px;"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="date" name="new_date" class="form-control" style="width:auto;padding:4px 8px;font-size:0.85rem;" required>
                            <input type="time" name="new_start" class="form-control" style="width:auto;padding:4px 8px;font-size:0.85rem;" required>
                            <span style="color:var(--gray-400);font-size:0.85rem;">to</span>
                            <input type="time" name="new_end" class="form-control" style="width:auto;padding:4px 8px;font-size:0.85rem;" required>
                            <button type="submit" class="btn btn-sm btn-primary" style="font-size:0.8rem;">Confirm Reschedule</button>
                        </form>
                    </details>
                    <% } %>
                </div>
                <% }); %>
            <% } else { %>
                <div class="card" style="padding:32px;text-align:center;margin-bottom:24px;"><p style="color:var(--gray-400);">No upcoming sessions. Students can book from the calendar once you set your availability below.</p></div>
            <% } %>

            <!-- MY STUDENTS -->
            <% if (students && students.length > 0) { %>
            <h2 style="font-size:1.25rem;margin:24px 0 16px;">My Students</h2>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:16px;margin-bottom:24px;">
                <% students.forEach(function(st) { %>
                <div class="card" style="padding:20px;">
                    <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
                        <div style="width:40px;height:40px;border-radius:50%;background:var(--yellow-100);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;color:var(--yellow-700);"><%= st.first_name ? st.first_name.charAt(0) : '' %><%= st.last_name ? st.last_name.charAt(0) : '' %></div>
                        <div><h4 style="font-size:0.95rem;"><%= st.first_name %> <%= st.last_name %></h4><p style="color:var(--gray-400);font-size:0.8rem;">Grade: <%= st.grade_level || 'N/A' %></p></div>
                    </div>
                    <div style="display:flex;gap:8px;">
                        <a href="/admin/tutor/report-card/<%= st.id %>" class="btn btn-outline btn-sm" style="font-size:0.8rem;">Report Card</a>
                        <a href="/parent/messages/<%= st.id %>" class="btn btn-outline btn-sm" style="font-size:0.8rem;">Message</a>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } %>

            <!-- AVAILABILITY -->
            <div class="card" style="margin-bottom:24px;padding:24px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                    <h2 style="font-size:1.15rem;">My Availability</h2>
                    <button type="button" id="save-avail-btn" class="btn btn-primary btn-sm">Save Availability</button>
                </div>
                <p style="color:var(--gray-400);font-size:0.85rem;margin-bottom:16px;">Add your available hours. Each slot must be exactly 1 hour. Students will book these slots directly.</p>
                <div id="availability-editor" data-existing='<%= JSON.stringify((availability || []).map(function(a) { return {day_of_week: a.day_of_week, start_time: a.start_time.substring(0,5), end_time: a.end_time.substring(0,5)}; })) %>'></div>
            </div>

            <!-- PROFILE -->
            <div class="card" style="margin-bottom:24px;padding:24px;">
                <h2 style="font-size:1.15rem;margin-bottom:16px;">My Profile</h2>
                <form id="tutor-profile-form" action="/admin/tutor/profile?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
                    <div class="form-row">
                        <div class="form-group"><label for="tagline">Tagline</label><input type="text" id="tagline" name="tagline" class="form-control" value="<%= profile.tagline || '' %>" placeholder="e.g., Making math fun since 2020"></div>
                        <div class="form-group">
                            <label for="subjects">Subjects</label>
                            <select id="subjects-select" class="form-control" multiple style="min-height:120px;">
                                <% subjectOptions.forEach(function(s) { %>
                                <option value="<%= s %>" <%= (profile.subjects || []).includes(s) ? 'selected' : '' %>><%= s %></option>
                                <% }); %>
                            </select>
                            <input type="hidden" name="subjects" id="subjects-hidden" value="<%= (profile.subjects || []).join(', ') %>">
                            <p style="font-size:0.8rem;color:var(--gray-400);margin-top:4px;">Hold Ctrl/Cmd to select multiple</p>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group"><label for="education">Education</label><input type="text" id="education" name="education" class="form-control" value="<%= profile.education || '' %>"></div>
                        <div class="form-group"><label for="experience_years">Years of Experience</label><input type="number" id="experience_years" name="experience_years" class="form-control" value="<%= profile.experience_years || 0 %>"></div>
                    </div>
                    <div class="form-group"><label for="bio">Bio</label><textarea id="bio" name="bio" class="form-control" rows="3"><%= profile.bio || '' %></textarea></div>
                    <div class="form-group"><label for="profile_picture">Profile Picture</label><input type="file" id="profile_picture" name="profile_picture" class="form-control" accept="image/*"></div>
                    <button type="submit" class="btn btn-primary btn-sm">Update Profile</button>
                </form>
            </div>
        </div>
    </div>
</main>

<script>
// Fix subjects hidden field on form submit (no onclick needed)
document.getElementById('tutor-profile-form').addEventListener('submit', function() {
    var sel = document.getElementById('subjects-select');
    var hidden = document.getElementById('subjects-hidden');
    var selected = [];
    for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].selected) selected.push(sel.options[i].value);
    }
    hidden.value = selected.join(', ');
});

// Wire save availability button
document.getElementById('save-avail-btn').addEventListener('click', function() {
    if (typeof saveAvailability === 'function') saveAvailability();
});
</script>

<%- include('../partials/footer') %>

<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<main id="main-content">
    <section class="section" style="padding-top:60px;">
        <div class="container" style="max-width:600px;text-align:center;width:100%;">
            <div class="card" style="padding:48px;">
                <div style="font-size:4rem;margin-bottom:16px;"></div>
                <h2 style="margin-bottom:12px;">Payment Successful!</h2>
                <p style="color:var(--gray-500);margin-bottom:32px;">Thank you for your payment. Your account has been updated and you can now book sessions.</p>
                <div style="display:flex;gap:12px;justify-content:center;">
                    <a href="<%= user.role === 'owner' ? '/admin/owner' : user.role === 'tutor' ? '/admin/tutor' : '/parent/dashboard' %>" class="btn btn-primary">Go to Dashboard</a>
                    <a href="/parent/calendar" class="btn btn-outline">Book a Session</a>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>

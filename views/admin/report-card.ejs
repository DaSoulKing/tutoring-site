<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<main id="main-content">
    <section class="section" style="padding-top:32px;">
        <div class="container" style="max-width:800px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                <div>
                    <h1 style="font-size:1.5rem;">Report Cards</h1>
                    <p style="color:var(--gray-500);font-size:0.9rem;">Student: <%= student.first_name %> <%= student.last_name %></p>
                </div>
                <a href="/admin/tutor" class="btn btn-outline btn-sm">&larr; Dashboard</a>
            </div>

            <!-- Create Report Card -->
            <div class="card" style="padding:24px;margin-bottom:32px;">
                <h3 style="font-size:1.1rem;margin-bottom:16px;">Create New Report Card</h3>
                <form action="/admin/tutor/report-card/<%= student.id %>" method="POST"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="term">Term/Period <span class="required">*</span></label>
                            <input type="text" id="term" name="term" class="form-control" required placeholder="e.g., Fall 2024">
                        </div>
                        <div class="form-group">
                            <label for="overall_grade">Overall Grade <span class="required">*</span></label>
                            <select id="overall_grade" name="overall_grade" class="form-control" required>
                                <option value="A+">A+</option><option value="A">A</option><option value="A-">A-</option>
                                <option value="B+">B+</option><option value="B">B</option><option value="B-">B-</option>
                                <option value="C+">C+</option><option value="C">C</option><option value="C-">C-</option>
                                <option value="D">D</option><option value="F">F</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="attendance_score">Attendance (0-100)</label>
                            <input type="number" id="attendance_score" name="attendance_score" class="form-control" min="0" max="100" value="85">
                        </div>
                        <div class="form-group">
                            <label for="participation_score">Participation (0-100)</label>
                            <input type="number" id="participation_score" name="participation_score" class="form-control" min="0" max="100" value="80">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="homework_score">Homework Completion (0-100)</label>
                        <input type="number" id="homework_score" name="homework_score" class="form-control" min="0" max="100" value="75">
                    </div>
                    <div class="form-group">
                        <label for="strengths">Strengths</label>
                        <textarea id="strengths" name="strengths" class="form-control" rows="3" placeholder="What the student excels at..."></textarea>
                    </div>
                    <div class="form-group">
                        <label for="areas_for_improvement">Areas for Improvement</label>
                        <textarea id="areas_for_improvement" name="areas_for_improvement" class="form-control" rows="3" placeholder="Where the student can grow..."></textarea>
                    </div>
                    <div class="form-group">
                        <label for="comments">General Comments</label>
                        <textarea id="comments" name="comments" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="goals_next_term">Goals for Next Term</label>
                        <textarea id="goals_next_term" name="goals_next_term" class="form-control" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Create Report Card</button>
                </form>
            </div>

            <!-- Existing Report Cards -->
            <% if (reportCards && reportCards.length > 0) { %>
            <h2 style="font-size:1.25rem;margin-bottom:20px;">Previous Report Cards</h2>
            <% reportCards.forEach(rc => { %>
            <div class="report-card" style="margin-bottom:32px;">
                <div class="report-card-header">
                    <p style="font-size:0.85rem;opacity:0.8;"><%= siteName %></p>
                    <h2>Student Report Card</h2>
                    <p><%= rc.term %> &middot; <%= new Date(rc.report_date).toLocaleDateString() %></p>
                </div>
                <div class="report-card-body">
                    <div class="report-card-row">
                        <span class="report-card-label">Student</span>
                        <span class="report-card-value"><%= student.first_name %> <%= student.last_name %></span>
                    </div>
                    <div class="report-card-row">
                        <span class="report-card-label">Overall Grade</span>
                        <div class="grade-badge grade-<%= (rc.overall_grade ? rc.overall_grade.charAt(0) : 'B') %>"><%= rc.overall_grade %></div>
                    </div>
                    <div class="report-card-row">
                        <span class="report-card-label">Attendance</span>
                        <div style="width:200px;">
                            <div class="score-bar"><div class="score-bar-fill" style="width:<%= rc.attendance_score || 0 %>%;"></div></div>
                            <span style="font-size:0.8rem;color:var(--gray-500);"><%= rc.attendance_score || 0 %>%</span>
                        </div>
                    </div>
                    <div class="report-card-row">
                        <span class="report-card-label">Participation</span>
                        <div style="width:200px;">
                            <div class="score-bar"><div class="score-bar-fill" style="width:<%= rc.participation_score || 0 %>%;"></div></div>
                            <span style="font-size:0.8rem;color:var(--gray-500);"><%= rc.participation_score || 0 %>%</span>
                        </div>
                    </div>
                    <div class="report-card-row">
                        <span class="report-card-label">Homework</span>
                        <div style="width:200px;">
                            <div class="score-bar"><div class="score-bar-fill" style="width:<%= rc.homework_score || 0 %>%;"></div></div>
                            <span style="font-size:0.8rem;color:var(--gray-500);"><%= rc.homework_score || 0 %>%</span>
                        </div>
                    </div>
                    <% if (rc.strengths) { %>
                    <div class="report-card-row" style="flex-direction:column;gap:4px;">
                        <span class="report-card-label">Strengths</span>
                        <p style="color:var(--gray-600);line-height:1.6;"><%= rc.strengths %></p>
                    </div>
                    <% } %>
                    <% if (rc.areas_for_improvement) { %>
                    <div class="report-card-row" style="flex-direction:column;gap:4px;">
                        <span class="report-card-label">Areas for Improvement</span>
                        <p style="color:var(--gray-600);line-height:1.6;"><%= rc.areas_for_improvement %></p>
                    </div>
                    <% } %>
                    <% if (rc.comments) { %>
                    <div class="report-card-row" style="flex-direction:column;gap:4px;">
                        <span class="report-card-label">Comments</span>
                        <p style="color:var(--gray-600);line-height:1.6;"><%= rc.comments %></p>
                    </div>
                    <% } %>
                    <% if (rc.goals_next_term) { %>
                    <div class="report-card-row" style="flex-direction:column;gap:4px;">
                        <span class="report-card-label">Goals for Next Term</span>
                        <p style="color:var(--gray-600);line-height:1.6;"><%= rc.goals_next_term %></p>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }); %>
            <% } %>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>

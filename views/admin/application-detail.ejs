<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <section class="section" style="padding-top:32px;">
        <div class="container" style="max-width:800px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                <h1 style="font-size:1.5rem;">Application Details</h1>
                <a href="/admin/owner" class="btn btn-outline btn-sm">&larr; Dashboard</a>
            </div>
            <div class="card" style="padding:32px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                    <div>
                        <h2 style="font-size:1.5rem;"><%= application.first_name %> <%= application.last_name %></h2>
                        <span class="badge-status badge-pending" style="font-size:0.9rem;"><%= application.applicant_type %> application</span>
                        <span class="badge-status badge-<%= application.status === 'accepted' ? 'active' : application.status === 'rejected' ? 'cancelled' : 'pending' %>"><%= application.status %></span>
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;">
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Email</label><p style="font-weight:600;"><%= application.email %></p></div>
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Phone</label><p style="font-weight:600;"><%= application.phone || 'Not provided' %></p></div>
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Subjects</label><p><% (application.subjects || []).forEach(s => { %><span class="subject-tag"><%= s %></span> <% }); %><%= (application.subjects || []).length === 0 ? 'None listed' : '' %></p></div>
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Education</label><p style="font-weight:600;"><%= application.education || 'Not provided' %></p></div>
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Availability</label><p style="font-weight:600;"><%= application.availability || 'Not provided' %></p></div>
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Applied</label><p style="font-weight:600;"><%= new Date(application.created_at).toLocaleDateString() %></p></div>
                </div>

                <% if (application.experience) { %>
                <div style="margin-bottom:20px;"><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Experience</label><p style="color:var(--gray-700);line-height:1.7;margin-top:4px;white-space:pre-wrap;"><%= application.experience %></p></div>
                <% } %>

                <% if (application.why_join) { %>
                <div style="margin-bottom:20px;"><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Why They Want to Join</label><p style="color:var(--gray-700);line-height:1.7;margin-top:4px;white-space:pre-wrap;"><%= application.why_join %></p></div>
                <% } %>

                <% if (application.cover_letter) { %>
                <div style="margin-bottom:20px;"><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Cover Letter</label><p style="color:var(--gray-700);line-height:1.7;margin-top:4px;white-space:pre-wrap;"><%= application.cover_letter %></p></div>
                <% } %>

                <% if (application.resume_path) { %>
                <div style="margin-bottom:24px;"><a href="<%= application.resume_path %>" target="_blank" class="btn btn-outline btn-sm">&#x1F4C4; View Resume</a></div>
                <% } %>

                <% if (application.status === 'pending') { %>
                <div style="border-top:2px solid var(--gray-100);padding-top:24px;display:flex;gap:12px;">
                    <form action="/admin/owner/applications/<%= application.id %>/status" method="POST">
                        <input type="hidden" name="status" value="accepted"><input type="hidden" name="reviewer_notes" value="">
                        <button type="submit" class="btn" style="background:var(--green-500);color:white;">Accept Application</button>
                    </form>
                    <form action="/admin/owner/applications/<%= application.id %>/status" method="POST">
                        <input type="hidden" name="status" value="rejected"><input type="hidden" name="reviewer_notes" value="">
                        <button type="submit" class="btn" style="background:var(--red-500);color:white;">Reject Application</button>
                    </form>
                </div>
                <% } %>
            </div>
        </div>
    </section>
</main>
<%- include('../partials/footer') %>

<%- include('../partials/header') %>
<%- include('../partials/nav') %>
<main id="main-content">
    <section class="section" style="padding-top:32px;">
        <div class="container" style="max-width:800px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                <h1 style="font-size:1.5rem;">Inquiry Details</h1>
                <a href="/admin/owner" class="btn btn-outline btn-sm">&larr; Dashboard</a>
            </div>
            <div class="card" style="padding:32px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                    <div>
                        <h2 style="font-size:1.5rem;"><%= inquiry.name %></h2>
                        <span class="badge-status badge-pending"><%= inquiry.inquiry_type %></span>
                        <span class="badge-status badge-<%= inquiry.status === 'resolved' ? 'active' : 'pending' %>"><%= inquiry.status %></span>
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;">
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Email</label><p style="font-weight:600;"><%= inquiry.email %></p></div>
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Phone</label><p style="font-weight:600;"><%= inquiry.phone || 'Not provided' %></p></div>
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Subject</label><p style="font-weight:600;"><%= inquiry.subject || 'N/A' %></p></div>
                    <div><label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Submitted</label><p style="font-weight:600;"><%= new Date(inquiry.created_at).toLocaleString() %></p></div>
                </div>

                <div style="margin-bottom:24px;">
                    <label style="font-size:0.8rem;color:var(--gray-400);font-weight:700;text-transform:uppercase;">Full Message</label>
                    <div style="margin-top:8px;padding:20px;background:var(--gray-50);border-radius:var(--radius);border:1px solid var(--gray-200);">
                        <p style="color:var(--gray-700);line-height:1.8;white-space:pre-wrap;"><%= inquiry.message %></p>
                    </div>
                </div>

                <% if (inquiry.status === 'open') { %>
                <form action="/admin/owner/inquiries/<%= inquiry.id %>/status" method="POST"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="status" value="resolved">
                    <button type="submit" class="btn btn-primary">Mark as Resolved</button>
                </form>
                <% } %>
            </div>
        </div>
    </section>
</main>
<%- include('../partials/footer') %>
